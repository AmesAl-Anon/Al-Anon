<!doctype html>
<html lang="{{ config.language }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{{ title }}</title>
    <meta name="description" content="{{ description or site.description }}">

    <link rel="stylesheet" href="{{ '/theme.css' | url }}">
    <link rel="icon" type="image/png" href="/_images/favicon.png" sizes="32x32">

    {% if page.url == "/" %}
        <! Ed H added Google Search Console verification meta tag. only needs to be in the home page 5/15/2026 
        to enable Google Search Console for the site.>
        {# This meta tag needed to verify ownership of the site for Google Search Console, 
        which provides insights into how the site is performing in Google search results. #}
        <meta name="google-site-verification" content="rUctYDvFsPCu89gqYTSM2iyHOlY55zcVypyfxvt44xk" />
    {% endif %}

    {% if layout === 'meeting.njk' %}
      <meta property="og:site_name" content="{{config.title}}" />
      <meta property="og:type" content="article" />
      <meta name="twitter:card" content="summary" />
      <meta property="og:title" content="{{ title }}" />
      <meta property="og:description" content="{{ description }}" />
      {% if permalink %}
        <meta property="og:url" content="https://{{config.domain}}{{ permalink }}" />
        {% else %}
        <meta property="og:url" content="https://{{config.domain}}{{ page.filePathStem }}/" />
      {% endif %}

      {% if featuredImage !== undefined %}
        <meta property="og:image" content="https://{{config.domain}}{{featuredImage}}" />
        {% else %}
        <meta property="og:image" content="https://{{config.domain}}/_images/default.jpg" />
      {% endif %}

    {% endif %}

    {# Ed removed custom.css
    {% set css %}
      {% include "custom.css" %}
    {% endset %}
    <style>
      {{ css | cssmin | safe }}
    </style> 
    #}

  </head>